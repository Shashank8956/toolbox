#!/usr/bin/env python3
"""
rdev — Remote Dev Sync Tool
Watches local repo files and instantly syncs changes to a remote staging server.
Select a server once, save files locally, build remotely — feels like working local.
"""

import sys
import os
import json
import signal
import socket
import logging
import tempfile
import subprocess
import yaml
from pathlib import Path
from datetime import datetime

SCRIPT_DIR  = Path(__file__).resolve().parent
PROJECT_DIR = SCRIPT_DIR.parent
CONFIG_FILE   = PROJECT_DIR / "config" / "rdev.yaml"
MACHINES_FILE = PROJECT_DIR / "config" / "machines.yaml"
PR_TEMPLATE   = PROJECT_DIR / "config" / "pr_template.md"
STATE_FILE    = Path.home() / ".rdev_state"
LOG_FILE      = PROJECT_DIR / "logs" / "rdev.log"

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[logging.FileHandler(LOG_FILE)]
)
logger = logging.getLogger(__name__)


# ── Config ────────────────────────────────────────────────────────────────────

class ConfigManager:
    def load(self):
        if not CONFIG_FILE.exists():
            print(f"❌ rdev.yaml not found at {CONFIG_FILE}")
            print(f"   Copy config/rdev.yaml.example to config/rdev.yaml and fill in your values.")
            sys.exit(1)
        with open(CONFIG_FILE) as f:
            return yaml.safe_load(f)

    def get_repo(self, name):
        cfg = self.load()
        repos = cfg.get('repos', {})
        if name not in repos:
            print(f"❌ Repo '{name}' not found in rdev.yaml. Available: {', '.join(repos)}")
            sys.exit(1)
        return repos[name]

    def list_repos(self):
        return self.load().get('repos', {})

    def default_repos(self):
        return self.load().get('default_repos', [])

    def jump_host(self):
        cfg = self.load()
        jh = cfg['jump_host']
        return f"{jh['user']}@{jh['ip']}"

    def local_root(self):
        return Path(self.load()['local_root'])

    def remote_root(self):
        return self.load()['remote_root']


class MachinesManager:
    def load(self):
        if not MACHINES_FILE.exists():
            print(f"❌ machines.yaml not found at {MACHINES_FILE}")
            sys.exit(1)
        with open(MACHINES_FILE) as f:
            return yaml.safe_load(f)

    def get_server(self, name):
        machines = self.load().get('machines', {})
        if name not in machines:
            available = ', '.join(machines.keys())
            print(f"❌ Server '{name}' not found in machines.yaml.")
            print(f"   Available: {available}")
            sys.exit(1)
        return machines[name]

    def list_servers(self):
        return self.load().get('machines', {})


# ── State ─────────────────────────────────────────────────────────────────────

class StateManager:
    def load(self):
        if not STATE_FILE.exists():
            return {}
        try:
            with open(STATE_FILE) as f:
                return json.load(f)
        except Exception:
            return {}

    def save(self, data):
        tmp = STATE_FILE.with_suffix('.tmp')
        with open(tmp, 'w') as f:
            json.dump(data, f, indent=2)
        tmp.rename(STATE_FILE)

    def update(self, **kwargs):
        state = self.load()
        state.update(kwargs)
        self.save(state)

    def clear(self):
        if STATE_FILE.exists():
            STATE_FILE.unlink()

    def require(self):
        """Load state or exit with a helpful error if no session is active."""
        state = self.load()
        if not state.get('server'):
            print("❌ No active session. Start one with: rdev start <server>")
            sys.exit(1)
        return state


# ── Daemon (background watcher) ───────────────────────────────────────────────

def _check_fswatch():
    result = subprocess.run(['which', 'fswatch'], capture_output=True)
    if result.returncode != 0:
        print("❌ fswatch is not installed.")
        print("   Install it with: brew install fswatch")
        sys.exit(1)


def _sync_file(changed_path, local_root, remote_root, repos, server_user, server_ip, bastion):
    """Rsync a single changed file to its corresponding remote path."""
    changed = Path(changed_path)
    for repo_name, repo in repos.items():
        local_repo = local_root / repo['local_path']
        if str(changed).startswith(str(local_repo) + '/') or changed == local_repo:
            try:
                rel = changed.relative_to(local_repo)
            except ValueError:
                continue
            rp = repo['remote_path']
            base = rp if rp.startswith('/') else f"{remote_root}/{rp}"
            remote_dir = f"{base}/{rel.parent}"
            if remote_dir.endswith('/.'):
                remote_dir = remote_dir[:-2]
            cmd = [
                'rsync', '-az',
                '--exclude=.git/',
                '--exclude=__pycache__/',
                '--exclude=*.pyc',
                '--exclude=node_modules/',
                '--exclude=tmp/',
                '--exclude=log/',
                '-e', f"ssh -J {bastion} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR",
                str(changed),
                f"{server_user}@{server_ip}:{remote_dir}/"
            ]
            result = subprocess.run(cmd, capture_output=True)
            if result.returncode == 0:
                logger.info(f"Synced: {repo_name}/{rel} → {server_ip}:{remote_dir}/")
            else:
                logger.error(f"rsync failed for {changed}: {result.stderr.decode()}")
            return
    logger.debug(f"Ignored (not in watched repos): {changed_path}")


def _run_daemon(server_name, repo_names):
    """The actual daemon loop. Called as a hidden subcommand."""
    cm = ConfigManager()
    mm = MachinesManager()

    cfg = cm.load()
    local_root = Path(cfg['local_root'])
    remote_root = cfg['remote_root']
    bastion = cm.jump_host()
    repos = {r: dict(cm.get_repo(r)) for r in repo_names}

    # Apply resolved paths from state (glob paths already expanded at session start)
    resolved = StateManager().load().get('resolved_paths', {})
    for r in repo_names:
        if r in resolved:
            repos[r]['remote_path'] = resolved[r]

    server = mm.get_server(server_name)
    server_ip   = server['ip']
    server_user = server.get('user', 'wti')

    watch_paths = [str(local_root / r['local_path']) for r in repos.values()]

    fswatch_cmd = [
        'fswatch',
        '--exclude=\\.git',
        '--exclude=__pycache__',
        '--exclude=\\.pyc$',
        '--exclude=node_modules',
        '--exclude=/tmp/',
        '--exclude=/log/',
    ] + watch_paths

    logger.info(f"Daemon started: watching {repo_names} → {server_name} ({server_ip})")

    proc = subprocess.Popen(fswatch_cmd, stdout=subprocess.PIPE)

    def shutdown(sig, frame):
        proc.terminate()
        logger.info("Daemon stopped")
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    # fswatch outputs one file path per line — readline() unblocks on each event
    while True:
        line = proc.stdout.readline()
        if not line:
            break
        changed = line.decode('utf-8', errors='replace').strip()
        if changed:
            _sync_file(changed, local_root, remote_root, repos, server_user, server_ip, bastion)


# ── SSH helpers ───────────────────────────────────────────────────────────────

def _ssh_base(server_ip, server_user, bastion):
    return [
        'ssh',
        '-o', f'ProxyJump={bastion}',
        '-o', 'StrictHostKeyChecking=no',
        '-o', 'UserKnownHostsFile=/dev/null',
        '-o', 'LogLevel=ERROR',
        f'{server_user}@{server_ip}',
    ]


def _ssh_stream(server_ip, server_user, bastion, remote_cmd):
    """Run a command on remote and stream its output live. Returns exit code."""
    cmd = _ssh_base(server_ip, server_user, bastion) + ['-t', remote_cmd]
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    try:
        for line in iter(proc.stdout.readline, b''):
            print(line.decode('utf-8', errors='replace'), end='', flush=True)
    except KeyboardInterrupt:
        proc.terminate()
    proc.wait()
    return proc.returncode


def _is_pid_alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _pr_body(ticket, target_branch):
    """Load pr_template.md and substitute ticket and target branch."""
    if not PR_TEMPLATE.exists():
        return ''
    body = PR_TEMPLATE.read_text()
    body = body.replace('{{TICKET}}', ticket)
    # Strip origin/ prefix and trailing .m for display (e.g. release/24.2.18.1.m → 24.2.18.1.m)
    display_branch = target_branch.replace('origin/release/', '').replace('origin/', '')
    body = body.replace('{{TARGET_BRANCH}}', display_branch)
    return body


def _resolve_remote_path(server_ip, server_user, bastion, path):
    """If path contains a glob (*), resolve it on the remote via SSH. Returns absolute path."""
    if '*' not in path:
        return path
    result = subprocess.run(
        _ssh_base(server_ip, server_user, bastion) + [f'ls -d {path} 2>/dev/null | head -1'],
        capture_output=True, text=True
    )
    resolved = result.stdout.strip()
    if not resolved:
        print(f"❌ Could not resolve remote path glob: {path}")
        sys.exit(1)
    return resolved


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_start(args):
    """Start a sync session: rdev start <server> [repo ...]"""
    if not args:
        print("Error: Usage: rdev start <server> [repo ...]")
        return 1

    _check_fswatch()

    server_name = args[0]
    cm = ConfigManager()
    mm = MachinesManager()

    repo_names = args[1:] if len(args) > 1 else cm.default_repos()
    if not repo_names:
        print("❌ No repos specified and no default_repos set in rdev.yaml")
        return 1

    # Validate all repos exist
    for r in repo_names:
        cm.get_repo(r)  # exits if not found

    # Validate server exists
    server = mm.get_server(server_name)
    server_ip   = server['ip']
    server_user = server.get('user', 'wti')
    bastion     = cm.jump_host()
    remote_root = cm.remote_root()

    # Check if a daemon is already running
    sm = StateManager()
    old = sm.load()
    if old.get('daemon_pid') and _is_pid_alive(old['daemon_pid']):
        print(f"⚠️  A watcher is already running (PID {old['daemon_pid']}) for {old.get('server')}.")
        print(f"   Run 'rdev stop' first to switch servers.")
        return 1

    # Resolve remote paths (handles globs like /home/wti/go*/src/ra)
    print(f"   Resolving remote paths on {server_name}...")
    resolved_paths = {}
    for r in repo_names:
        repo = cm.get_repo(r)
        rp = repo.get('remote_path', r)
        full = rp if rp.startswith('/') else f"{remote_root}/{rp}"
        resolved_paths[r] = _resolve_remote_path(server_ip, server_user, bastion, full)
        if '*' in rp:
            print(f"   {r}: {resolved_paths[r]}")

    # Save session state
    sm.save({
        'server': server_name,
        'server_ip': server_ip,
        'server_user': server_user,
        'watching': repo_names,
        'resolved_paths': resolved_paths,
        'daemon_pid': None,
        'started_at': datetime.now().isoformat(),
    })

    # Spawn background daemon (self-fork)
    log_fd = open(LOG_FILE, 'a')
    proc = subprocess.Popen(
        [sys.argv[0], '_daemon', server_name] + repo_names,
        stdout=log_fd,
        stderr=log_fd,
        start_new_session=True,
    )
    log_fd.close()
    sm.update(daemon_pid=proc.pid)

    print(f"✅ Session started")
    print(f"   Server : {server_name} ({server['ip']})")
    print(f"   Watching: {', '.join(repo_names)}")
    print(f"   Daemon  : PID {proc.pid}")
    print(f"   Logs    : rdev logs")
    return 0


def cmd_stop(args):
    """Stop the active sync session."""
    sm = StateManager()
    state = sm.load()
    pid = state.get('daemon_pid')

    if not pid:
        print("No active session.")
        sm.clear()
        return 0

    if _is_pid_alive(pid):
        os.kill(pid, signal.SIGTERM)
        print(f"✅ Stopped daemon (PID {pid})")
    else:
        print(f"Daemon PID {pid} was already gone.")

    sm.clear()
    return 0


def cmd_status(args):
    """Show active session status."""
    sm = StateManager()
    state = sm.load()

    if not state.get('server'):
        print("No active session. Start one with: rdev start <server>")
        return 0

    pid = state.get('daemon_pid')
    alive = pid and _is_pid_alive(pid)

    print()
    print(f"  Server   : {state['server']} ({state.get('server_ip', '?')})")
    print(f"  Watching : {', '.join(state.get('watching', []))}")
    print(f"  Daemon   : PID {pid} {'✅ running' if alive else '❌ dead — run: rdev start ' + state['server']}")
    print(f"  Started  : {state.get('started_at', '?')}")
    print()
    return 0


def cmd_build(args):
    """Run remote build: rdev build [repo]"""
    sm = StateManager()
    state = sm.require()
    cm = ConfigManager()

    repo_name = args[0] if args else state['watching'][0]
    repo = cm.get_repo(repo_name)

    build = repo.get('build', {})
    build_cmd = build.get('cmd')
    if not build_cmd:
        print(f"❌ No build.cmd configured for repo '{repo_name}' in rdev.yaml")
        return 1

    remote_dir = state.get('resolved_paths', {}).get(repo_name)
    if not remote_dir:
        remote_root = cm.remote_root()
        rp = repo['remote_path']
        remote_dir = rp if rp.startswith('/') else f"{remote_root}/{rp}"
    bastion = cm.jump_host()

    print(f"\n🔨 Building {repo_name} on {state['server']}...")
    print(f"   Command: {build_cmd}")
    print(f"   Dir    : {remote_dir}")
    print("─" * 60)

    rc = _ssh_stream(
        state['server_ip'], state['server_user'], bastion,
        f"bash -li -c 'cd {remote_dir} && {build_cmd}'"
    )

    print("─" * 60)

    post_cmd = build.get('post_cmd')
    if post_cmd and rc == 0:
        print(f"\n🔁 Running post-build: {post_cmd}")
        print("─" * 60)
        rc = _ssh_stream(
            state['server_ip'], state['server_user'], bastion,
            f"bash -li -c 'cd {remote_dir} && {post_cmd}'"
        )
        print("─" * 60)

    if rc == 0:
        print(f"\n✅ Build finished successfully")
    else:
        print(f"\n❌ Build exited with code {rc}")
    return rc


def cmd_git(args):
    """Run a git command locally and mirror it on the remote for each watched repo."""
    if not args:
        print("Error: Usage: rdev git <git-args>")
        return 1

    sm = StateManager()
    state = sm.require()
    cm = ConfigManager()

    local_root = cm.local_root()
    remote_root = cm.remote_root()
    bastion = cm.jump_host()

    # Run locally in erp root
    print(f"\n[local] git {' '.join(args)}")
    result = subprocess.run(['git'] + args, cwd=str(local_root))
    if result.returncode != 0:
        return result.returncode

    # If it was a checkout, also update submodules locally
    if args[0] == 'checkout':
        subprocess.run(['git', 'submodule', 'update', '--init', '--recursive'], cwd=str(local_root))

    # Mirror on remote for each watched repo
    for repo_name in state['watching']:
        repo = cm.get_repo(repo_name)
        remote_dir = state.get('resolved_paths', {}).get(repo_name)
        if not remote_dir:
            rp = repo['remote_path']
            remote_dir = rp if rp.startswith('/') else f"{remote_root}/{rp}"
        print(f"\n[remote:{repo_name}] git {' '.join(args)}")
        subprocess.run(
            _ssh_base(state['server_ip'], state['server_user'], bastion) +
            [f"cd {remote_dir} && git {' '.join(args)}"]
        )

    return 0


def cmd_branch(args):
    """Create local branches for a ticket across repos.

    rdev branch WEMAIN-XXXXX 24 25 dmt [other ...]

    Suffixes resolve to origin branches via branch_targets in rdev.yaml.
    Unknown suffixes are appended to origin/release/.
    Repos come from branch_repos in rdev.yaml (or --repos override).
    """
    if len(args) < 2:
        print("Error: Usage: rdev branch <TICKET> <suffix> [suffix ...] [--repos r1,r2]")
        return 1

    cm = ConfigManager()
    cfg = cm.load()

    ticket = args[0].replace('\u2013', '-').replace('\u2014', '-')
    rest = args[1:]

    # Parse optional --repos override
    repo_names = None
    if '--repos' in rest:
        idx = rest.index('--repos')
        repo_names = rest[idx + 1].split(',')
        rest = rest[:idx] + rest[idx + 2:]

    suffixes = rest
    if not suffixes:
        print("Error: Specify at least one branch suffix (e.g. 24 25 dmt)")
        return 1

    if repo_names is None:
        repo_names = cfg.get('branch_repos', list(cfg.get('repos', {}).keys()))

    targets = {str(k): v for k, v in cfg.get('branch_targets', {}).items()}
    local_root = Path(cfg['local_root'])
    remote_root = cm.remote_root()
    bastion = cm.jump_host()

    # Load active session if any (optional — branch works without one)
    sm = StateManager()
    try:
        state = sm.require()
    except SystemExit:
        state = None

    failed = False
    for suffix in suffixes:
        is_numeric = suffix.rstrip('x').isdigit()
        branch_name = f"{ticket}--{suffix}x" if is_numeric else f"{ticket}--{suffix}"
        if suffix in targets:
            origin_branch = targets[suffix]
        else:
            origin_branch = f"origin/release/{suffix}"

        print(f"\n── {branch_name} → {origin_branch} " + "─" * 30)
        for repo_name in repo_names:
            repo_dir = local_root / cfg['repos'][repo_name]['local_path']
            print(f"  [{repo_name}] git checkout -b {branch_name} {origin_branch}")
            result = subprocess.run(
                ['git', 'checkout', '-b', branch_name, origin_branch],
                cwd=str(repo_dir), capture_output=True, text=True
            )
            if result.returncode != 0 and 'already exists' in result.stderr:
                print(f"  [{repo_name}] branch exists, switching to it")
                result = subprocess.run(
                    ['git', 'checkout', branch_name],
                    cwd=str(repo_dir), capture_output=True, text=True
                )
            if result.returncode == 0:
                print(f"  [{repo_name}] git pull")
                subprocess.run(['git', 'pull'], cwd=str(repo_dir))

                if state:
                    repo_cfg = cfg['repos'][repo_name]
                    remote_dir = state.get('resolved_paths', {}).get(repo_name)
                    if not remote_dir:
                        rp = repo_cfg['remote_path']
                        remote_dir = rp if rp.startswith('/') else f"{remote_root}/{rp}"
                    remote_cmd = f"cd {remote_dir} && git fetch origin && (git checkout -b {branch_name} {origin_branch} 2>/dev/null || git checkout {branch_name}) && git pull"
                    print(f"  [{repo_name}] remote: git checkout -b {branch_name} {origin_branch}")
                    subprocess.run(
                        _ssh_base(state['server_ip'], state['server_user'], bastion) + [remote_cmd]
                    )

                print(f"  ✅ {repo_name}: done")
            else:
                print(f"  ❌ {repo_name}: {result.stderr.strip()}")
                failed = True

    return 1 if failed else 0


def cmd_raise_pr(args):
    """Cherry-pick current branch commits to all sibling ticket branches and raise PRs.

    rdev raise-pr "Commit message"

    Detects the current branch (must match TICKET--SUFFIX pattern), finds all
    sibling branches for the same ticket, cherry-picks commits, pushes, and
    opens a PR for each via `gh pr create`.
    """
    if not args:
        print("Error: Usage: rdev raise-pr \"Commit message\"")
        return 1

    commit_msg = args[0]
    cm = ConfigManager()
    cfg = cm.load()
    local_root = Path(cfg['local_root'])
    targets = {str(k): v for k, v in cfg.get('branch_targets', {}).items()}

    # Detect which repo we're in from cwd
    cwd = Path.cwd()
    repo_name = None
    repo_dir = None
    for name, repo in cfg.get('repos', {}).items():
        candidate = local_root / repo['local_path']
        try:
            cwd.relative_to(candidate)
            repo_name = name
            repo_dir = candidate
            break
        except ValueError:
            continue
    if not repo_name:
        print(f"❌ Not inside a known repo. cwd: {cwd}")
        print(f"   Known repos: {', '.join(cfg.get('repos', {}).keys())}")
        return 1

    # Detect current branch
    result = subprocess.run(['git', 'rev-parse', '--abbrev-ref', 'HEAD'],
                            cwd=str(repo_dir), capture_output=True, text=True)
    current_branch = result.stdout.strip()

    # Normalize em-dash variants (–- or —) to double hyphen for parsing
    normalized_branch = current_branch.replace('\u2013-', '--').replace('\u2014', '--')

    if '--' not in normalized_branch:
        print(f"❌ Current branch '{current_branch}' doesn't match TICKET--SUFFIX format")
        return 1

    ticket_normalized = normalized_branch.rsplit('--', 1)[0]
    # ticket prefix in actual branch name may still have em-dash; derive from current_branch directly
    ticket_raw = current_branch[:len(ticket_normalized)]

    # Find all sibling branches (match both -- and –- variants)
    result = subprocess.run(['git', 'branch', '--list'],
                            cwd=str(repo_dir), capture_output=True, text=True)
    all_branches_raw = [b.strip().lstrip('* ') for b in result.stdout.splitlines() if b.strip()]
    # Normalize each branch name for comparison, keep original for git ops
    def normalize(b):
        return b.replace('\u2013-', '--').replace('\u2014', '--')
    all_branches = [b for b in all_branches_raw if normalize(b).startswith(ticket_normalized + '--')]
    sibling_branches = [b for b in all_branches if b != current_branch]

    if not sibling_branches:
        print(f"No sibling branches found for {ticket}. Raising PR only for current branch.")

    # Compute the current branch's own base (commits the user actually made)
    current_suffix = normalize(current_branch).rsplit('--', 1)[1]
    current_base = targets.get(current_suffix, targets.get(current_suffix.rstrip('x'), f"origin/release/{current_suffix}"))
    base_commits_result = subprocess.run(
        ['git', 'log', '--pretty=format:%H', f"{current_base}..{current_branch}"],
        cwd=str(repo_dir), capture_output=True, text=True
    )
    feature_commits = [c for c in base_commits_result.stdout.strip().split('\n') if c]

    if not feature_commits and sibling_branches:
        print(f"❌ Current branch '{current_branch}' has no commits ahead of {current_base}.")
        print(f"   Run raise-pr from the branch where you made your changes.")
        return 1

    print(f"  Repo    : {repo_name}")
    print(f"  Base    : {current_base} ({len(feature_commits)} commit(s) to carry)")
    print(f"  Branches: {', '.join([current_branch] + sibling_branches)}")

    failed = False
    pr_links = []

    for branch in [current_branch] + sibling_branches:
        is_current = (branch == current_branch)
        print(f"\n── {'[current] ' if is_current else ''}PR for {branch} " + "─" * 30)

        if is_current:
            # Commit staged/unstaged changes
            subprocess.run(['git', 'add', '-A'], cwd=str(repo_dir), capture_output=True)
            commit_result = subprocess.run(['git', 'commit', '-m', commit_msg],
                                           cwd=str(repo_dir), capture_output=True, text=True)
            if commit_result.returncode != 0 and 'nothing to commit' not in commit_result.stdout:
                print(f"  ❌ commit failed: {commit_result.stderr.strip()}")
                failed = True
                continue
            print(f"  committed")
        else:
            if not feature_commits:
                print(f"  no commits to cherry-pick")
                continue

            print(f"  checking out {branch}")
            subprocess.run(['git', 'checkout', branch], cwd=str(repo_dir), capture_output=True)

            # Use git cherry to find commits not yet applied to this branch (by patch content)
            cherry_result = subprocess.run(
                ['git', 'cherry', branch, current_branch],
                cwd=str(repo_dir), capture_output=True, text=True
            )
            pending_shas = set(
                line.split()[1] for line in cherry_result.stdout.splitlines()
                if line.startswith('+')
            )
            commits_to_apply = [sha for sha in reversed(feature_commits) if sha in pending_shas]
            already_present = len(feature_commits) - len(commits_to_apply)
            if already_present:
                print(f"  {already_present} commit(s) already present on {branch}, skipping")
            if not commits_to_apply:
                print(f"  nothing new to cherry-pick")
            else:
                print(f"  cherry-picking {len(commits_to_apply)} commit(s)")

            cherry_pick_failed = False
            for sha in commits_to_apply:
                cp = subprocess.run(['git', 'cherry-pick', sha],
                                    cwd=str(repo_dir), capture_output=True, text=True)
                if cp.returncode != 0:
                    stderr = cp.stderr.strip()
                    print(f"  ❌ cherry-pick {sha[:8]} failed: {stderr}")
                    print(f"     Resolve conflicts then run: git cherry-pick --continue")
                    failed = True
                    cherry_pick_failed = True
                    break
            if cherry_pick_failed:
                continue

        # Push
        print(f"  pushing {branch}")
        push = subprocess.run(['git', 'push', '-u', 'origin', branch],
                              cwd=str(repo_dir), capture_output=True, text=True)
        if push.returncode != 0:
            print(f"  ❌ push failed: {push.stderr.strip()}")
            failed = True
            continue
        print(f"  pushed")

        # Determine base branch for PR
        suffix = normalize(branch).rsplit('--', 1)[1]
        origin_branch = targets.get(suffix, targets.get(suffix.rstrip('x'), f"origin/release/{suffix}"))
        base_branch = origin_branch.replace('origin/', '')

        pr = subprocess.run(
            ['gh', 'pr', 'create', '--repo', f"waterfield/{repo_name}",
             '--title', commit_msg, '--body', _pr_body(ticket_normalized, origin_branch),
             '--base', base_branch, '--head', branch],
            cwd=str(repo_dir), capture_output=True, text=True
        )
        if pr.returncode == 0:
            url = pr.stdout.strip()
            pr_links.append((branch, url))
            print(f"  ✅ PR created: {url}")
        else:
            stderr = pr.stderr.strip()
            if 'already exists' in stderr.lower():
                # Fetch existing PR URL
                existing = subprocess.run(
                    ['gh', 'pr', 'view', branch, '--repo', f"waterfield/{repo_name}", '--json', 'url', '--jq', '.url'],
                    cwd=str(repo_dir), capture_output=True, text=True
                )
                url = existing.stdout.strip()
                if url:
                    pr_links.append((branch, url))
                    print(f"  ✅ PR already exists: {url}")
                else:
                    print(f"  ⚠️  PR already exists (could not fetch URL)")
            else:
                print(f"  ❌ PR failed: {stderr}")
                failed = True

    print("\n── PRs raised " + "─" * 50)
    if pr_links:
        for branch, url in pr_links:
            print(f"  {branch}: {url}")
    else:
        print("  (none succeeded)")

    return 1 if failed else 0


def cmd_wgod(args):
    """Run wgod status/start/restart on the active remote server."""
    subcmd = args[0] if args else 'status'
    if subcmd not in ('status', 'start', 'restart'):
        print("Error: Usage: rdev wgod [status|start|restart]")
        return 1

    sm = StateManager()
    state = sm.require()
    cm = ConfigManager()
    bastion = cm.jump_host()

    print(f"[{state['server']}] wgod {subcmd}")
    return _ssh_stream(state['server_ip'], state['server_user'], bastion,
                       f"bash -li -c 'wgod {subcmd}'")


def cmd_exec(args):
    """Run an arbitrary command on the active remote server."""
    if not args:
        print("Error: Usage: rdev exec <command>")
        return 1

    sm = StateManager()
    state = sm.require()
    cm = ConfigManager()

    remote_cmd = ' '.join(args)
    bastion = cm.jump_host()

    print(f"[{state['server']}] {remote_cmd}")
    return _ssh_stream(state['server_ip'], state['server_user'], bastion, remote_cmd)


def cmd_list(args):
    """List servers and configured repos."""
    cm = ConfigManager()
    mm = MachinesManager()
    sm = StateManager()
    state = sm.load()
    active = state.get('server')

    print("\n── Servers (from machines.yaml) " + "─" * 40)
    servers = mm.list_servers()
    for name, details in servers.items():
        marker = " ← active" if name == active else ""
        print(f"  {name:<25} {details['ip']}{marker}")

    print("\n── Repos (from rdev.yaml) " + "─" * 46)
    repos = cm.list_repos()
    defaults = cm.default_repos()
    for name, repo in repos.items():
        default_marker = " [default]" if name in defaults else ""
        build_cmd = repo.get('build', {}).get('cmd', '—')
        print(f"  {name:<25} build: {build_cmd}{default_marker}")
    print()
    return 0


def cmd_logs(args):
    """Tail remote app log files.

    rdev logs                     tail -f all *.log (real-time)
    rdev logs <file>              tail -f specific file (real-time)
    rdev logs -n <N>              last N lines from all *.log (static)
    rdev logs <file> -n <N>       last N lines from specific file (static)
    """
    sm = StateManager()
    state = sm.require()
    cm = ConfigManager()
    bastion = cm.jump_host()

    # Parse args: optional filename, optional -n N
    filename = None
    tail_n = None
    i = 0
    while i < len(args):
        if args[i] == '-n' and i + 1 < len(args):
            tail_n = int(args[i + 1])
            i += 2
        elif not args[i].startswith('-'):
            filename = args[i]
            i += 1
        else:
            i += 1

    # Find the repo with a log_dir configured, default to first watched repo
    repo_name = None
    repo = None
    for r in state.get('watching', []):
        cfg_repo = cm.get_repo(r)
        if cfg_repo.get('log_dir'):
            repo_name = r
            repo = cfg_repo
            break
    if not repo:
        # Fall back to first watched repo with default log_dir 'log'
        repo_name = state['watching'][0]
        repo = cm.get_repo(repo_name)

    remote_dir = state.get('resolved_paths', {}).get(repo_name)
    if not remote_dir:
        remote_root = cm.remote_root()
        rp = repo['remote_path']
        remote_dir = rp if rp.startswith('/') else f"{remote_root}/{rp}"

    log_dir = repo.get('log_dir', 'log')
    log_path = f"{remote_dir}/{log_dir}"
    target = f"{log_path}/{filename}" if filename else f"{log_path}/*.log"

    if tail_n is not None:
        print(f"[{state['server']}] tail -n {tail_n} {target}")
        return _ssh_stream(state['server_ip'], state['server_user'], bastion,
                           f"bash -c 'tail -n {tail_n} {target}'")
    else:
        print(f"[{state['server']}] tail -f {target}  (Ctrl+C to stop)")
        return _ssh_stream(state['server_ip'], state['server_user'], bastion,
                           f"bash -c 'tail -f {target}'")


def cmd_sync_logs(args):
    """Show local rdev daemon sync log entries."""
    if not LOG_FILE.exists():
        print("No sync logs yet.")
        return 0
    with open(LOG_FILE) as f:
        lines = f.readlines()
    n = int(args[0]) if args else 50
    print(''.join(lines[-n:]))
    return 0


def print_usage():
    print("""
rdev — Remote Dev Sync Tool

Usage:
  rdev start <server> [repo ...]   Start sync session (default repos from config)
  rdev stop                        Stop active session and watcher daemon
  rdev status                      Show session info and daemon health
  rdev build [repo]                Run remote build, stream output live
  rdev git <git-args>              Run git cmd locally + mirror on remote repos
  rdev branch <TICKET> <suffix...>  Create local branches across repos for a ticket
  rdev raise-pr "Commit message"   Commit, cherry-pick to siblings, push and raise PRs
  rdev wgod [status|start|restart] Run wgod on active server (default: status)
  rdev exec <cmd>                  Run any command on remote, stream output
  rdev list                        List servers and configured repos
  rdev logs                        Tail all *.log on remote in real-time
  rdev logs <file>                 Tail specific log file in real-time
  rdev logs -n <N>                 Show last N lines from all *.log
  rdev logs <file> -n <N>          Show last N lines from specific file
  rdev sync-logs [n]               Show local rdev daemon log (default 50 lines)
  rdev help                        Show this help

Examples:
  rdev start tallgrass-project
  rdev start tallgrass-project go-ra
  rdev build go-ra
  rdev build revenue_accounting
  rdev logs
  rdev logs production.log
  rdev logs -n 100
  rdev logs production.log -n 50
  rdev git checkout main
  rdev exec "ps aux | grep wgod"
  rdev stop
    """)


def main():
    if len(sys.argv) < 2:
        print_usage()
        return 1

    command = sys.argv[1]
    args = sys.argv[2:]

    # Hidden internal subcommand: the daemon itself
    if command == '_daemon':
        if len(args) < 2:
            print("Internal use only: _daemon <server> <repo> [repo ...]")
            return 1
        _run_daemon(server_name=args[0], repo_names=args[1:])
        return 0

    commands = {
        'start':  cmd_start,
        'stop':   cmd_stop,
        'status': cmd_status,
        'build':  cmd_build,
        'git':    cmd_git,
        'branch':   cmd_branch,
        'raise-pr': cmd_raise_pr,
        'wgod':     cmd_wgod,
        'exec':   cmd_exec,
        'list':   cmd_list,
        'logs':      cmd_logs,
        'sync-logs': cmd_sync_logs,
        'help':   lambda x: (print_usage(), 0)[1],
    }

    if command not in commands:
        print(f"Unknown command: {command}")
        print_usage()
        return 1

    try:
        return commands[command](args)
    except KeyboardInterrupt:
        print("\nCancelled.")
        return 1
    except Exception as e:
        logger.error(f"Unexpected error: {e}", exc_info=True)
        print(f"❌ Error: {e}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
